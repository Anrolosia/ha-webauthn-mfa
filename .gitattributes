# Force LF line endings on all text files
* text=auto eol=lf

# Explicitly declare text files
*.py    text eol=lf
*.json  text eol=lf
*.yaml  text eol=lf
*.yml   text eol=lf
*.js    text eol=lf
*.md    text eol=lf
*.txt   text eol=lf
*.html  text eol=lf
*.css   text eol=lf

# Binary files — never touch line endings
*.png   binary
*.jpg   binary
*.ico   binary
*.gif   binary
*.zip   binary
